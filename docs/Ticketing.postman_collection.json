{
	"info": {
		"_postman_id": "ticketing-system-api",
		"name": "Ticketing System API",
		"description": "Complete API collection for the Ticketing System.\n\n## Authentication\n- Cookie-based JWT (httpOnly)\n- Login sets `access_token` and `refresh_token` cookies automatically\n- Dev bypass: `X-Super-Secret-Key` header (DEBUG mode only)\n\n## Setup\n1. Set `base_url` variable to your backend URL\n2. Run the Login request first\n3. Cookies are managed automatically by Postman",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8002", "type": "string" },
		{ "key": "project_id", "value": "1", "type": "string" },
		{ "key": "ticket_id", "value": "1", "type": "string" },
		{ "key": "company_id", "value": "1", "type": "string" },
		{ "key": "user_id", "value": "1", "type": "string" },
		{ "key": "column_id", "value": "1", "type": "string" },
		{ "key": "tag_id", "value": "1", "type": "string" },
		{ "key": "comment_id", "value": "1", "type": "string" },
		{ "key": "room_id", "value": "1", "type": "string" },
		{ "key": "notification_id", "value": "1", "type": "string" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"securepassword123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\"\n}"
						},
						"url": "{{base_url}}/api/tickets/auth/register/"
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"boris\",\n  \"password\": \"your_password\"\n}"
						},
						"url": "{{base_url}}/api/tickets/auth/login/"
					}
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/api/tickets/auth/me/"
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/api/tickets/auth/token/refresh/"
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/api/tickets/auth/logout/"
					}
				},
				{
					"name": "Password Reset - Request",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"source\": \"admin\"\n}"
						},
						"url": "{{base_url}}/api/tickets/auth/password-reset/",
						"description": "Always returns 200 to not leak user existence. Source: 'admin' or 'servicedesk'."
					}
				},
				{
					"name": "Password Reset - Validate Token",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"uid\": \"MTI\",\n  \"token\": \"abc123-tokenhere\"\n}"
						},
						"url": "{{base_url}}/api/tickets/auth/password-reset/validate/"
					}
				},
				{
					"name": "Password Reset - Confirm",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"uid\": \"MTI\",\n  \"token\": \"abc123-tokenhere\",\n  \"new_password\": \"newsecurepassword123\"\n}"
						},
						"url": "{{base_url}}/api/tickets/auth/password-reset/confirm/"
					}
				}
			]
		},
